# =============================================================================
# GRC Webapp — PRODUCTION environment template
# =============================================================================
# Copy to ".env.prod" in the repository root:  cp .env.prod.example .env.prod
# chmod 600 .env.prod
# Never commit the real file.
#
# Docker Compose reads this file via env_file: .env.prod
# For variable substitution during `docker compose build`, run:
#   docker compose --env-file .env.prod -f docker-compose.prod.yml build
# =============================================================================

# --- Django ------------------------------------------------------------------
SECRET_KEY=
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
# Must be long, random, and unique per environment.

DEBUG=false

# Comma-separated hostnames (no https://). Must include your public hostname.
ALLOWED_HOSTS=app.example.com

# Full public URL of the web UI (scheme + host, no trailing path)
FRONTEND_URL=https://app.example.com

DJANGO_SETTINGS_MODULE=core.settings.prod

# Required behind HTTPS reverse proxy: exact origins the browser uses
CSRF_TRUSTED_ORIGINS=https://app.example.com

# Custom Django admin URL path — do NOT use "admin/" in production.
# Example:  python3 -c "import uuid; print(str(uuid.uuid4()) + '/')"
ADMIN_URL=

SHOW_API_DOCS=false

SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true

# --- PostgreSQL (docker-compose.prod service: db) ---------------------------
DATABASE_URL=postgresql://grc:REPLACE_DB_PASSWORD@db:5432/grc_prod

POSTGRES_DB=grc_prod
POSTGRES_USER=grc
POSTGRES_PASSWORD=
# Strong password (20+ characters). Must match DATABASE_URL credentials.

# --- Redis (docker-compose.prod — password required) ------------------------
# URL must include the password: redis://:PASSWORD@redis:6379/0
REDIS_URL=redis://:REPLACE_REDIS_PASSWORD@redis:6379/0

REDIS_PASSWORD=
# Same password as in REDIS_URL. Used by the redis container.

# --- Fernet (encrypt SMTP credentials stored in database) --------------------
FERNET_KEY=
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# --- Backup encryption at-rest (OBBLIGATORIO in produzione, newfix R4) -------
# Cifra AES-256-GCM i pg_dump nel volume backupdata. DEVE essere distinta da
# FERNET_KEY: chi compromette le credenziali backup non deve poter decifrare
# anche i secret operativi.
BACKUP_ENCRYPTION_KEY=
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"

# --- Outbound email (production SMTP) ----------------------------------------
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=GRC Platform <noreply@example.com>

# --- Celery workers ----------------------------------------------------------
CELERY_CONCURRENCY=4

# Optional: local path for DB dumps inside the container (default /app/backups)
# BACKUP_DIR=/app/backups

# --- File storage ------------------------------------------------------------
# local = files on backend volume; s3 = object storage
STORAGE_BACKEND=local
# S3_ENDPOINT_URL=https://s3.example.com
# S3_BUCKET_NAME=grc-documents
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# --- Optional: AI Engine ------------------------------------------------------
AI_ENGINE_ENABLED=false
AI_LOCAL_ENDPOINT=http://ollama:11434
AI_LOCAL_MODEL=llama3.1:8b
AI_CLOUD_PROVIDER=azure
AZURE_OPENAI_KEY=
ANTHROPIC_API_KEY=

# --- Optional: KnowBe4 --------------------------------------------------------
KNOWBE4_API_KEY=
KNOWBE4_SYNC_ENABLED=false

# --- Audit trail retention (years) -----------------------------------------
AUDIT_TRAIL_RETENTION_L1_YEARS=5
AUDIT_TRAIL_RETENTION_L2_YEARS=3
AUDIT_TRAIL_RETENTION_L3_YEARS=1

# --- Sentry (backend) — leave blank to disable -------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0

# Backend release tag (optional, for Sentry)
APP_VERSION=1.0.0

# --- Frontend build arguments (docker-compose.prod frontend service) ---------
# Passed at image build time. Same-origin API: leave VITE_API_URL empty so the
# browser calls /api/v1 on the same host as the SPA.
VITE_API_URL=
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_TRACES_RATE=0.1
VITE_APP_VERSION=1.0.0
