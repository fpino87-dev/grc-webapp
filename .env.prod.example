# GRC Platform — Configurazione PRODUZIONE
# Copia in .env.prod e compila tutti i valori

# Django
SECRET_KEY=<genera: python -c "import secrets; print(secrets.token_urlsafe(50))">
DEBUG=false
ALLOWED_HOSTS=grc.tuaazienda.com
FRONTEND_URL=https://grc.tuaazienda.com
DJANGO_SETTINGS_MODULE=core.settings.prod
# OBBLIGATORIO se dietro Nginx Proxy Manager / reverse proxy con HTTPS
CSRF_TRUSTED_ORIGINS=https://grc.tuaazienda.com

# Sicurezza — Admin URL (NON usare "admin/" in produzione!)
# Genera un path non predicibile, es: python -c "import uuid; print(uuid.uuid4())"
ADMIN_URL=<uuid-casuale>/

# API docs (Swagger): lasciare false in produzione
SHOW_API_DOCS=false

# Cookie security (impostare true quando HTTPS è attivo)
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true

# Database
DATABASE_URL=postgresql://grc:PASSWORD_DB@db:5432/grc_prod
POSTGRES_DB=grc_prod
POSTGRES_USER=grc
POSTGRES_PASSWORD=<password sicura min 20 caratteri>

# Redis
REDIS_URL=redis://:PASSWORD_REDIS@redis:6379/0
REDIS_PASSWORD=<password sicura min 20 caratteri>

# Cifratura credenziali SMTP (Fernet AES-256)
# Genera con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=<chiave Fernet base64>

# Email SMTP
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=noreply@tuaazienda.com
EMAIL_HOST_PASSWORD=<password app SMTP>
DEFAULT_FROM_EMAIL=GRC Platform <noreply@tuaazienda.com>

# Celery
CELERY_CONCURRENCY=4

# Storage (locale o S3)
STORAGE_BACKEND=local
# Se S3:
# STORAGE_BACKEND=s3
# S3_ENDPOINT_URL=https://s3.tuaazienda.com
# S3_BUCKET_NAME=grc-documents
# S3_ACCESS_KEY=...
# S3_SECRET_KEY=...

# AI Engine (opzionale)
AI_ENGINE_ENABLED=false
AI_LOCAL_ENDPOINT=http://ollama:11434
AI_LOCAL_MODEL=llama3.1:8b

# KnowBe4 (opzionale)
KNOWBE4_API_KEY=
KNOWBE4_SYNC_ENABLED=false

# Audit trail retention
AUDIT_TRAIL_RETENTION_L1_YEARS=5
AUDIT_TRAIL_RETENTION_L2_YEARS=3
AUDIT_TRAIL_RETENTION_L3_YEARS=1
