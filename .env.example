# =============================================================================
# GRC Webapp — LOCAL DEVELOPMENT environment template
# =============================================================================
# Copy to ".env" in the repository root:  cp .env.example .env
# Never commit the real ".env" file. Generate secrets locally (see below).
# =============================================================================

# --- Django core -------------------------------------------------------------
# Random string, min ~50 characters. Generate:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-generate-a-long-random-string

# true for dev; must be false in production
DEBUG=true

# Comma-separated hostnames that may serve this Django app (no scheme)
ALLOWED_HOSTS=localhost,127.0.0.1

# Public URL of the frontend as the user’s browser sees it (scheme + host [+ port])
# Dev Docker maps the Vite app to http://localhost:3001
FRONTEND_URL=http://localhost:3001

# When using HTTPS or a reverse proxy, list trusted origins for CSRF (scheme required)
# Example: https://app.example.com
CSRF_TRUSTED_ORIGINS=

# Django admin URL path. Use a non-default value in production.
ADMIN_URL=admin/

# Expose Swagger/OpenAPI UI (set false in production)
SHOW_API_DOCS=true

# --- Database (PostgreSQL) ---------------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Docker Compose dev service "db" is reachable as host "db" from other containers.
DATABASE_URL=postgresql://grc:grc@db:5432/grc_dev

# --- Redis (cache + Celery broker) ------------------------------------------
# Service name "redis" when using docker-compose.yml
REDIS_URL=redis://redis:6379/0

# --- Object storage (MinIO / S3) --------------------------------------------
# local = filesystem under MEDIA_ROOT; s3 = remote bucket
STORAGE_BACKEND=local
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET_NAME=grc-documents
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# --- Email (development) -----------------------------------------------------
# Note: backend/core/settings/dev.py currently sets EMAIL_HOST/PORT for Mailhog.
# Adjust dev.py if you need the backend container to reach the mailhog service by name.
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USE_TLS=false
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# --- Optional integrations ----------------------------------------------------
KNOWBE4_API_KEY=
KNOWBE4_SYNC_ENABLED=false

# --- AI Engine (optional) ---------------------------------------------------
AI_ENGINE_ENABLED=false
# From backend container, use service name or host.docker.internal for host LLM
AI_LOCAL_ENDPOINT=http://host.docker.internal:11434
AI_LOCAL_MODEL=llama3.2:3b
AI_CLOUD_PROVIDER=azure
AZURE_OPENAI_KEY=
ANTHROPIC_API_KEY=

# --- Audit log retention (years) ---------------------------------------------
AUDIT_TRAIL_RETENTION_L1_YEARS=5
AUDIT_TRAIL_RETENTION_L2_YEARS=3
AUDIT_TRAIL_RETENTION_L3_YEARS=1

# --- Fernet key (encrypt SMTP passwords stored in DB) ------------------------
# Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# --- Backup encryption (newfix R4) -------------------------------------------
# Cifra at-rest i pg_dump nel volume backupdata (AES-256-GCM con key derivata
# via PBKDF2-HMAC-SHA256 200k iterazioni). DEVE essere distinta da FERNET_KEY
# (separazione di compromessi). Vuota = backup in chiaro (solo dev).
# Generate:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
BACKUP_ENCRYPTION_KEY=

# --- Celery ------------------------------------------------------------------
CELERY_CONCURRENCY=4

# --- Sentry (backend) — leave empty to disable -------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0

# --- Sentry (frontend, Vite dev / build) -------------------------------------
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_RATE=0.1
VITE_APP_VERSION=dev
